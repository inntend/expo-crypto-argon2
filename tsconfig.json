{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "Node16",
    "target": "ES2019",
    "moduleResolution": "node16",
    "strict": true,
    "outDir": "build",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react"
  },
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}
